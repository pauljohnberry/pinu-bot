{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "files": {
    "includes": [
      "*.json",
      "src/**/*.ts",
      "scripts/**/*.ts",
      "scripts/**/*.mjs",
      "demo/**/*.html",
      "test/**/*.ts",
      "test/**/*.html",
      ".github/**/*.yml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
